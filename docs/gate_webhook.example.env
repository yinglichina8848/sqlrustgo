# Gate Webhook Configuration
# Copy to gate_webhook.env and configure

# Webhook endpoint URL
GATE_WEBHOOK_URL=https://your-webhook-endpoint.com/gate

# Webhook secret for HMAC signature (optional)
GATE_WEBHOOK_SECRET=your-secret-key

# Notification settings
GATE_WEBHOOK_ENABLED=true

# Alert levels
GATE_WEBHOOK_ON_VIOLATION=true
GATE_WEBHOOK_ON_PASSED=false
