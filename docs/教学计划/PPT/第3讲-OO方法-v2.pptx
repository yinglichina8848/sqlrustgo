\begin{frame}{第18页：确定对象属性（初步）}
\protect\phantomsection\label{ux7b2c18ux9875ux786eux5b9aux5bf9ux8c61ux5c5eux6027ux521dux6b65}
\begin{block}{属性识别原则}
\protect\phantomsection\label{ux5c5eux6027ux8bc6ux522bux539fux5219}
\begin{itemize}
\tightlist
\item
  \textbf{特征信息}：描述对象的静态特征
\item
  \textbf{状态信息}：描述对象的动态状态（会变化）
\item
  \textbf{避免冗余}：可通过计算获得的不要存储
\end{itemize}
\end{block}

\begin{block}{图书管理系统对象属性}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux5bf9ux8c61ux5c5eux6027}
{\def\LTcaptype{none} % do not increment counter
