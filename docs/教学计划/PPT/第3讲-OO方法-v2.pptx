\section{第三讲：面向对象分析、设计与实现}\label{ux7b2cux4e09ux8bb2ux9762ux5411ux5bf9ux8c61ux5206ux6790ux8bbeux8ba1ux4e0eux5b9eux73b0}

\begin{frame}{从结构化到面向对象的方法演进}
\protect\phantomsection\label{ux4eceux7ed3ux6784ux5316ux5230ux9762ux5411ux5bf9ux8c61ux7684ux65b9ux6cd5ux6f14ux8fdb}
\begin{block}{以高校图书管理系统为例}
\protect\phantomsection\label{ux4ee5ux9ad8ux6821ux56feux4e66ux7ba1ux7406ux7cfbux7edfux4e3aux4f8b}
\textbf{80分钟 \textbar{} 两节课}
\end{block}
\end{frame}

\begin{frame}
\end{frame}

\section{第一部分：OO的历史与演进（What \&
Why）}\label{ux7b2cux4e00ux90e8ux5206ooux7684ux5386ux53f2ux4e0eux6f14ux8fdbwhat-why}

\begin{frame}{第一部分：OO的历史与演进（What \& Why）}
\emph{本部分回答：OO从何而来？为什么需要OO？}
\end{frame}

\begin{frame}{第1页：软件危机与结构化方法（1960s-1980s）}
\protect\phantomsection\label{ux7b2c1ux9875ux8f6fux4ef6ux5371ux673aux4e0eux7ed3ux6784ux5316ux65b9ux6cd51960s-1980s}
\begin{block}{历史背景}
\protect\phantomsection\label{ux5386ux53f2ux80ccux666f}
\begin{itemize}
\tightlist
\item
  \textbf{1960年代-1970年代}：软件规模爆炸，项目频繁延期
\item
  \textbf{典型问题}：

  \begin{itemize}
  \tightlist
  \item
    需求变更导致大规模返工
  \item
    代码难以维护，``修复一个bug引入三个bug''
  \item
    团队沟通困难，文档与代码脱节
  \end{itemize}
\end{itemize}
\end{block}

\begin{block}{结构化方法的诞生}
\protect\phantomsection\label{ux7ed3ux6784ux5316ux65b9ux6cd5ux7684ux8bdeux751f}
\begin{itemize}
\tightlist
\item
  \textbf{核心思想}：自顶向下、逐步求精、功能分解
\item
  \textbf{三大建模工具}：

  \begin{itemize}
  \tightlist
  \item
    数据流图（DFD）：描述功能处理过程
  \item
    实体-关系图（ERD）：描述数据结构
  \item
    流程图/状态图：描述行为逻辑
  \end{itemize}
\end{itemize}
\end{block}
\end{frame}

\begin{frame}[fragile]{第2页：结构化方法的核心缺陷}
\protect\phantomsection\label{ux7b2c2ux9875ux7ed3ux6784ux5316ux65b9ux6cd5ux7684ux6838ux5fc3ux7f3aux9677}
\begin{block}{数据与操作分离}
\protect\phantomsection\label{ux6570ux636eux4e0eux64cdux4f5cux5206ux79bb}
\begin{verbatim}
[学生数据] ←→ [借书处理程序] ←→ [图书数据]
     ↑              ↓              ↑
   数据库        业务逻辑        数据库
\end{verbatim}
\end{block}

\begin{block}{痛点示例：图书管理系统需求变更}
\protect\phantomsection\label{ux75dbux70b9ux793aux4f8bux56feux4e66ux7ba1ux7406ux7cfbux7edfux9700ux6c42ux53d8ux66f4}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}ll@{}}
\toprule\noalign{}
需求变更 & 结构化方法的影响 \\
\midrule\noalign{}
\endhead
增加''教师借书期限不同'' & 修改所有涉及期限计算的处理程序 \\
增加''预约图书功能'' & 修改学生、图书、借阅三个数据结构和处理程序 \\
增加''电子书借阅'' & 新增数据文件，修改大部分现有程序 \\
\bottomrule\noalign{}
\end{longtable}
}

\textbf{本质问题}：数据和操作分离，导致\textbf{变化传播范围广}
\end{block}
\end{frame}

\begin{frame}{第3页：面向对象方法的诞生（1980s-1990s）}
\protect\phantomsection\label{ux7b2c3ux9875ux9762ux5411ux5bf9ux8c61ux65b9ux6cd5ux7684ux8bdeux751f1980s-1990s}
\begin{block}{图形界面革命的推动}
\protect\phantomsection\label{ux56feux5f62ux754cux9762ux9769ux547dux7684ux63a8ux52a8}
\begin{itemize}
\tightlist
\item
  \textbf{1980年代}：Macintosh、Windows等图形操作系统普及
\item
  \textbf{界面元素天然具有对象特征}：

  \begin{itemize}
  \tightlist
  \item
    窗口：有状态（大小、位置）和行为（打开、关闭）
  \item
    按钮：有状态（启用/禁用）和行为（点击响应）
  \item
    菜单、对话框、图标\ldots{}
  \end{itemize}
\end{itemize}
\end{block}

\begin{block}{面向对象的核心洞察}
\protect\phantomsection\label{ux9762ux5411ux5bf9ux8c61ux7684ux6838ux5fc3ux6d1eux5bdf}
\begin{quote}
\textbf{``软件系统应该像现实世界一样，由自治的对象组成，对象通过消息协作完成任务''}
\end{quote}

\begin{itemize}
\tightlist
\item
  \textbf{Simula（1967）}：首次引入''类''和''对象''概念
\item
  \textbf{Smalltalk（1970s）}：第一个纯面向对象语言
\item
  \textbf{C++（1980s）}：将OO带入主流工程实践
\end{itemize}
\end{block}
\end{frame}

\begin{frame}{第4页：面向对象发展简史}
\protect\phantomsection\label{ux7b2c4ux9875ux9762ux5411ux5bf9ux8c61ux53d1ux5c55ux7b80ux53f2}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}lll@{}}
\toprule\noalign{}
年代 & 里程碑 & 关键贡献 \\
\midrule\noalign{}
\endhead
1960s & Simula 67 & 引入''类''和''对象''概念 \\
1970s & Smalltalk & 第一个纯OO语言，完善消息传递机制 \\
1980s & C++ & 将OO带入主流工程实践，兼容C语言 \\
1990s & Java & 纯OO语言，跨平台，企业级应用 \\
1997 & UML 1.0 & 统一建模语言，成为OMG标准 \\
2005 & UML 2.0 & 扩展图的数量和精确性 \\
\bottomrule\noalign{}
\end{longtable}
}
\end{frame}

\begin{frame}{第5页：方法演进对比（What）}
\protect\phantomsection\label{ux7b2c5ux9875ux65b9ux6cd5ux6f14ux8fdbux5bf9ux6bd4what}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}lll@{}}
\toprule\noalign{}
维度 & 结构化方法 & 面向对象方法 \\
\midrule\noalign{}
\endhead
\textbf{基本单位} & 功能模块 & 对象（数据+操作封装） \\
\textbf{系统视角} & 功能分解 & 责任分配与协作 \\
\textbf{应对变化} & 修改连锁反应 & 局部修改，不影响其他对象 \\
\textbf{复用方式} & 代码复制或函数库 & 继承、组合、多态 \\
\textbf{建模工具} & DFD、ERD、流程图 &
UML用例图、类图、顺序图\ldots{} \\
\textbf{适合场景} & 数据处理型系统 & 交互密集型、复杂业务系统 \\
\bottomrule\noalign{}
\end{longtable}
}

\begin{block}{图书管理系统示例}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux793aux4f8b}
\begin{itemize}
\tightlist
\item
  \textbf{结构化}：先设计''借书处理''功能，再设计所需的数据结构
\item
  \textbf{面向对象}：先识别''学生''、``图书''、``借阅记录''等对象，再设计它们的协作
\end{itemize}
\end{block}
\end{frame}

\begin{frame}{第6页：OO核心思想：责任驱动（What）}
\protect\phantomsection\label{ux7b2c6ux9875ooux6838ux5fc3ux601dux60f3ux8d23ux4efbux9a71ux52a8what}
\begin{block}{什么是对象？}
\protect\phantomsection\label{ux4ec0ux4e48ux662fux5bf9ux8c61}
\begin{quote}
\textbf{对象 = 责任（Responsibility）的封装体}
\end{quote}
\end{block}

\begin{block}{三大特征详解}
\protect\phantomsection\label{ux4e09ux5927ux7279ux5f81ux8be6ux89e3}
\begin{itemize}
\tightlist
\item
  \textbf{封装（Encapsulation）}：隐藏内部细节，只暴露必要接口

  \begin{itemize}
  \tightlist
  \item
    图书对象知道如何检查是否可借，外界无需知道具体规则
  \item
    学生对象管理自己的借阅记录，外界不能直接修改
  \end{itemize}
\item
  \textbf{继承（Inheritance）}：复用和扩展责任

  \begin{itemize}
  \tightlist
  \item
    ``教师''和''学生''复用''用户''的基础责任，各自扩展特殊责任
  \item
    避免重复代码，支持层次分类
  \end{itemize}
\item
  \textbf{多态（Polymorphism）}：替换责任执行者

  \begin{itemize}
  \tightlist
  \item
    无论是教师还是学生，都通过统一的''借书''接口处理
  \item
    系统可以统一处理不同类型的用户
  \end{itemize}
\end{itemize}
\end{block}
\end{frame}

\begin{frame}{第7页：Why OO？应对软件复杂性}
\protect\phantomsection\label{ux7b2c7ux9875why-ooux5e94ux5bf9ux8f6fux4ef6ux590dux6742ux6027}
\begin{block}{复杂性来源与OO解决方案}
\protect\phantomsection\label{ux590dux6742ux6027ux6765ux6e90ux4e0eooux89e3ux51b3ux65b9ux6848}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\linewidth - 4\tabcolsep) * \real{0.1905}}
  >{\raggedright\arraybackslash}p{(\linewidth - 4\tabcolsep) * \real{0.2619}}
  >{\raggedright\arraybackslash}p{(\linewidth - 4\tabcolsep) * \real{0.5476}}@{}}
\toprule\noalign{}
\begin{minipage}[b]{\linewidth}\raggedright
复杂性来源
\end{minipage} & \begin{minipage}[b]{\linewidth}\raggedright
OO解决方案
\end{minipage} & \begin{minipage}[b]{\linewidth}\raggedright
图书管理系统示例
\end{minipage} \\
\midrule\noalign{}
\endhead
\textbf{认知负担} & 封装隐藏细节 &
学生只需知道''借书''接口，无需了解库存检查逻辑 \\
\textbf{需求变化} & 继承和多态支持扩展 &
新增''访客''用户类型，继承基础用户类即可 \\
\textbf{团队协作} & 对象职责清晰，接口明确 &
前端团队与后端团队通过''借书接口''契约协作 \\
\textbf{系统演化} & 对象自治，修改局部化 &
修改逾期罚款规则，只影响''借阅记录''对象 \\
\bottomrule\noalign{}
\end{longtable}
}
\end{block}
\end{frame}

\begin{frame}{第8页：OO vs 结构化：修改成本对比（Why）}
\protect\phantomsection\label{ux7b2c8ux9875oo-vs-ux7ed3ux6784ux5316ux4feeux6539ux6210ux672cux5bf9ux6bd4why}
\begin{block}{场景：图书管理系统增加''电子书借阅''}
\protect\phantomsection\label{ux573aux666fux56feux4e66ux7ba1ux7406ux7cfbux7edfux589eux52a0ux7535ux5b50ux4e66ux501fux9605}
\textbf{结构化方法修改范围}：

\begin{itemize}
\tightlist
\item
  修改学生数据结构（增加电子书权限字段）
\item
  修改图书数据结构（增加介质类型字段）
\item
  修改借书处理程序（增加电子书特殊逻辑）
\item
  修改还书处理程序（增加电子书自动归还逻辑）
\item
  修改查询程序、统计程序\ldots{}
\item
  \textbf{影响范围：整个系统}
\end{itemize}

\textbf{面向对象方法修改范围}：

\begin{itemize}
\tightlist
\item
  新增''EBook''类（继承Book）
\item
  修改''借书''方法（增加电子书特殊处理）
\item
  \textbf{影响范围：两个类}
\end{itemize}
\end{block}
\end{frame}

\begin{frame}[fragile]{第9页：从现实到软件：OO建模的本质（What）}
\protect\phantomsection\label{ux7b2c9ux9875ux4eceux73b0ux5b9eux5230ux8f6fux4ef6ooux5efaux6a21ux7684ux672cux8d28what}
\begin{block}{图书管理系统的现实世界}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux7684ux73b0ux5b9eux4e16ux754c}
\begin{verbatim}
现实世界                    软件系统
─────────                   ─────────
学生 ──借书──→ 图书          Student对象 ──消息──→ Book对象
   │                            │
   └── 产生 ──→ 借阅记录        └── 创建 ──→ BorrowRecord对象
\end{verbatim}
\end{block}

\begin{block}{OOA/OOD/OOP的关系}
\protect\phantomsection\label{ooaoodoopux7684ux5173ux7cfb}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\linewidth - 4\tabcolsep) * \real{0.3846}}
  >{\raggedright\arraybackslash}p{(\linewidth - 4\tabcolsep) * \real{0.2821}}
