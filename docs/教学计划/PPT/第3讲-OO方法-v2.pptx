\protect\phantomsection\label{ux4f18ux5316ux540eux7684ux5bf9ux8c61ux5217ux8868}
\begin{itemize}
\tightlist
\item
  User（用户）← Student, Teacher, Librarian
\item
  Book（图书）
\item
  LibraryBranch（分馆）
\item
  BorrowRecord（借阅记录）
\item
  Reservation（预约记录）
\end{itemize}
\end{block}
\end{frame}

\begin{frame}[fragile]{第21页：OOA阶段产出：概念类图}
\protect\phantomsection\label{ux7b2c21ux9875ooaux9636ux6bb5ux4ea7ux51faux6982ux5ff5ux7c7bux56fe}
\begin{block}{概念类图规范}
\protect\phantomsection\label{ux6982ux5ff5ux7c7bux56feux89c4ux8303}
\begin{itemize}
\tightlist
\item
  \textbf{类名}：业务概念名称（中文或英文）
\item
  \textbf{属性}：只写名称，不写类型和可见性（分析阶段不关心）
\item
  \textbf{方法}：不写或只写关键业务方法
\item
  \textbf{关系}：关联、继承、聚合、组合
\end{itemize}
\end{block}

