\bottomrule\noalign{}
\end{longtable}
}
\end{block}
\end{frame}

\begin{frame}[fragile]{第10页：本讲目标与结构（How）}
\protect\phantomsection\label{ux7b2c10ux9875ux672cux8bb2ux76eeux6807ux4e0eux7ed3ux6784how}
\begin{block}{学习目标}
\protect\phantomsection\label{ux5b66ux4e60ux76eeux6807}
\begin{enumerate}
\tightlist
\item
  \textbf{理解} OO思想的核心（责任、封装、协作）
\item
  \textbf{掌握} OOA过程（从需求发现对象）
\item
  \textbf{掌握} OOD过程（设计类、应用SOLID原则）
\item
  \textbf{能够} 完成图书管理系统的OOA/OOD
\end{enumerate}
\end{block}

\begin{block}{课程结构}
\protect\phantomsection\label{ux8bfeux7a0bux7ed3ux6784}
\begin{verbatim}
第一节课（40分钟）：OOA分析过程
├── 需求获取与用例分析
├── 名词分析法发现对象
└── 建立概念类图

第二节课（40分钟）：OOD设计过程
├── 从分析到设计的过渡
├── 详细类设计（属性、方法、关系）
├── SOLID设计原则应用
└── 设计优化与评审
