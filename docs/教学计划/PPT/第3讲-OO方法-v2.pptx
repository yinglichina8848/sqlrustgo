\section{课间休息（5分钟）}\label{ux8bfeux95f4ux4f11ux606f5ux5206ux949f}

\begin{frame}
\end{frame}

\section{第三部分：从OOA到OOD}\label{ux7b2cux4e09ux90e8ux5206ux4eceooaux5230ood}

\begin{frame}{第三部分：从OOA到OOD}
\emph{本部分回答：如何将分析模型转化为设计模型？}
\end{frame}

\begin{frame}[fragile]{第22页：OOA vs OOD：关键区别}
\protect\phantomsection\label{ux7b2c22ux9875ooa-vs-oodux5173ux952eux533aux522b}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}lll@{}}
\toprule\noalign{}
维度 & OOA（分析） & OOD（设计） \\
\midrule\noalign{}
\endhead
\textbf{关注点} & 问题域（What） & 解决方案（How） \\
\textbf{抽象层次} & 概念层（业务概念） & 逻辑层（软件组件） \\
\textbf{技术细节} & 不涉及 & 涉及（数据库、接口、框架） \\
\textbf{属性定义} & 名称即可 & 名称+类型+可见性+约束 \\
\textbf{方法定义} & 业务责任 & 具体方法签名+算法 \\
\textbf{关系实现} & 概念关联 & 具体实现（引用、集合、外键） \\
\bottomrule\noalign{}
\end{longtable}
}

\begin{block}{映射关系示例}
\protect\phantomsection\label{ux6620ux5c04ux5173ux7cfbux793aux4f8b}
\begin{verbatim}
OOA: 用户 ──借阅──► 图书  （概念关联）
        ↓
OOD: User类持有BorrowRecord列表引用
     Book类持有BorrowRecord列表引用
     BorrowRecord持有User和Book的引用
\end{verbatim}
\end{block}
\end{frame}

\begin{frame}{第23页：OOD的核心任务}
\protect\phantomsection\label{ux7b2c23ux9875oodux7684ux6838ux5fc3ux4efbux52a1}
\begin{block}{设计阶段任务清单}
\protect\phantomsection\label{ux8bbeux8ba1ux9636ux6bb5ux4efbux52a1ux6e05ux5355}
\begin{enumerate}
\tightlist
\item
  \textbf{细化类设计}

  \begin{itemize}
  \tightlist
  \item
    确定属性和方法的完整签名
  \item
    确定可见性（public/private/protected）
  \item
    确定数据类型和约束
  \end{itemize}
\item
  \textbf{设计关系实现}

  \begin{itemize}
  \tightlist
  \item
    关联→引用或集合
  \item
    继承→ extends/implements
  \item
    依赖→参数传递或局部变量
  \end{itemize}
\item
  \textbf{应用设计原则}

  \begin{itemize}
  \tightlist
  \item
    SOLID原则指导类设计
  \item
    设计模式解决常见问题
  \end{itemize}
\item
  \textbf{设计交互}

  \begin{itemize}
  \tightlist
  \item
    用顺序图描述对象协作
  \item
    用状态图描述对象生命周期
  \end{itemize}
\end{enumerate}
\end{block}
\end{frame}

\begin{frame}[fragile]{第24页：图书管理系统：从分析到设计}
\protect\phantomsection\label{ux7b2c24ux9875ux56feux4e66ux7ba1ux7406ux7cfbux7edfux4eceux5206ux6790ux5230ux8bbeux8ba1}
\begin{block}{分析类 → 设计类转换示例}
\protect\phantomsection\label{ux5206ux6790ux7c7b-ux8bbeux8ba1ux7c7bux8f6cux6362ux793aux4f8b}
\textbf{OOA阶段：User类}

\begin{verbatim}
User
- userId
- name
- email
- 借书()
- 还书()
\end{verbatim}

\textbf{OOD阶段：User类}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{public} \KeywordTok{abstract} \KeywordTok{class}\NormalTok{ User }\OperatorTok{\{}
    \KeywordTok{private} \BuiltInTok{String}\NormalTok{ userId}\OperatorTok{;}          \CommentTok{// 私有，通过getter访问}
    \KeywordTok{private} \BuiltInTok{String}\NormalTok{ name}\OperatorTok{;}
    \KeywordTok{private} \BuiltInTok{String}\NormalTok{ email}\OperatorTok{;}
    \KeywordTok{private} \BuiltInTok{List}\OperatorTok{\textless{}}\NormalTok{BorrowRecord}\OperatorTok{\textgreater{}}\NormalTok{ borrowRecords}\OperatorTok{;}  \CommentTok{// 关联实现}
    
    \KeywordTok{public} \DataTypeTok{boolean} \FunctionTok{canBorrow}\OperatorTok{()} \OperatorTok{\{}    \CommentTok{// 业务规则封装}
        \ControlFlowTok{return}\NormalTok{ borrowRecords}\OperatorTok{.}\FunctionTok{stream}\OperatorTok{()}
               \OperatorTok{.}\FunctionTok{filter}\OperatorTok{(}\NormalTok{r }\OperatorTok{{-}\textgreater{}}\NormalTok{ r}\OperatorTok{.}\FunctionTok{getStatus}\OperatorTok{()} \OperatorTok{==}\NormalTok{ BorrowStatus}\OperatorTok{.}\FunctionTok{BORROWED}\OperatorTok{)}
               \OperatorTok{.}\FunctionTok{count}\OperatorTok{()} \OperatorTok{\textless{}} \FunctionTok{getMaxBooks}\OperatorTok{();}
    \OperatorTok{\}}
    
    \KeywordTok{public} \KeywordTok{abstract} \DataTypeTok{int} \FunctionTok{getMaxBooks}\OperatorTok{();}  \CommentTok{// 子类实现不同限额}
    
    \KeywordTok{public}\NormalTok{ BorrowRecord }\FunctionTok{borrowBook}\OperatorTok{(}\BuiltInTok{Book}\NormalTok{ book}\OperatorTok{)} \KeywordTok{throws}\NormalTok{ BorrowException }\OperatorTok{\{}
        \ControlFlowTok{if} \OperatorTok{(!}\FunctionTok{canBorrow}\OperatorTok{())} \ControlFlowTok{throw} \KeywordTok{new} \FunctionTok{BorrowException}\OperatorTok{(}\StringTok{"超出借书限额"}\OperatorTok{);}
        \ControlFlowTok{if} \OperatorTok{(!}\NormalTok{book}\OperatorTok{.}\FunctionTok{isAvailable}\OperatorTok{())} \ControlFlowTok{throw} \KeywordTok{new} \FunctionTok{BorrowException}\OperatorTok{(}\StringTok{"图书不可借"}\OperatorTok{);}
        
\NormalTok{        BorrowRecord }\KeywordTok{record} \OperatorTok{=} \KeywordTok{new} \FunctionTok{BorrowRecord}\OperatorTok{(}\KeywordTok{this}\OperatorTok{,}\NormalTok{ book}\OperatorTok{);}
\NormalTok{        borrowRecords}\OperatorTok{.}\FunctionTok{add}\OperatorTok{(}\KeywordTok{record}\OperatorTok{);}
\NormalTok{        book}\OperatorTok{.}\FunctionTok{setStatus}\OperatorTok{(}\NormalTok{BookStatus}\OperatorTok{.}\FunctionTok{BORROWED}\OperatorTok{);}
        \ControlFlowTok{return} \KeywordTok{record}\OperatorTok{;}
    \OperatorTok{\}}
\OperatorTok{\}}
\end{Highlighting}
\end{Shaded}
\end{block}
\end{frame}

\begin{frame}[fragile]{第25页：关联关系的实现设计}
\protect\phantomsection\label{ux7b2c25ux9875ux5173ux8054ux5173ux7cfbux7684ux5b9eux73b0ux8bbeux8ba1}
\begin{block}{1对多关联的实现}
\protect\phantomsection\label{ux5bf9ux591aux5173ux8054ux7684ux5b9eux73b0}
\textbf{场景}：一个用户有多个借阅记录

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{public} \KeywordTok{class}\NormalTok{ User }\OperatorTok{\{}
    \KeywordTok{private} \BuiltInTok{List}\OperatorTok{\textless{}}\NormalTok{BorrowRecord}\OperatorTok{\textgreater{}}\NormalTok{ borrowRecords }\OperatorTok{=} \KeywordTok{new} \BuiltInTok{ArrayList}\OperatorTok{\textless{}\textgreater{}();}
    
    \KeywordTok{public} \DataTypeTok{void} \FunctionTok{addBorrowRecord}\OperatorTok{(}\NormalTok{BorrowRecord }\KeywordTok{record}\OperatorTok{)} \OperatorTok{\{}
\NormalTok{        borrowRecords}\OperatorTok{.}\FunctionTok{add}\OperatorTok{(}\KeywordTok{record}\OperatorTok{);}
        \KeywordTok{record}\OperatorTok{.}\FunctionTok{setUser}\OperatorTok{(}\KeywordTok{this}\OperatorTok{);}  \CommentTok{// 维护双向关联}
    \OperatorTok{\}}
\OperatorTok{\}}

\KeywordTok{public} \KeywordTok{class}\NormalTok{ BorrowRecord }\OperatorTok{\{}
    \KeywordTok{private}\NormalTok{ User user}\OperatorTok{;}  \CommentTok{// 外键引用}
    \KeywordTok{private} \BuiltInTok{Book}\NormalTok{ book}\OperatorTok{;}
    
    \KeywordTok{public} \DataTypeTok{void} \FunctionTok{setUser}\OperatorTok{(}\NormalTok{User user}\OperatorTok{)} \OperatorTok{\{}
        \KeywordTok{this}\OperatorTok{.}\FunctionTok{user} \OperatorTok{=}\NormalTok{ user}\OperatorTok{;}
    \OperatorTok{\}}
\OperatorTok{\}}
\end{Highlighting}
\end{Shaded}
\end{block}

\begin{block}{设计决策}
\protect\phantomsection\label{ux8bbeux8ba1ux51b3ux7b56}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}lll@{}}
\toprule\noalign{}
决策 & 选择 & 理由 \\
\midrule\noalign{}
\endhead
双向关联 & 是 & 需要从记录查找用户，也需要从用户查找记录 \\
集合类型 & ArrayList & 有序，支持快速遍历 \\
级联操作 & 添加记录时双向设置 & 保持数据一致性 \\
\bottomrule\noalign{}
\end{longtable}
}
\end{block}
\end{frame}

\begin{frame}[fragile]{第26页：继承关系的实现设计}
\protect\phantomsection\label{ux7b2c26ux9875ux7ee7ux627fux5173ux7cfbux7684ux5b9eux73b0ux8bbeux8ba1}
\begin{block}{User继承体系设计}
\protect\phantomsection\label{userux7ee7ux627fux4f53ux7cfbux8bbeux8ba1}
\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{public} \KeywordTok{abstract} \KeywordTok{class}\NormalTok{ User }\OperatorTok{\{}
    \KeywordTok{protected} \BuiltInTok{String}\NormalTok{ userId}\OperatorTok{;}    \CommentTok{// protected：子类可访问}
    \KeywordTok{protected} \BuiltInTok{String}\NormalTok{ name}\OperatorTok{;}
    
    \KeywordTok{public} \KeywordTok{abstract} \DataTypeTok{int} \FunctionTok{getMaxBooks}\OperatorTok{();}  \CommentTok{// 抽象方法}
    \KeywordTok{public} \KeywordTok{abstract} \DataTypeTok{int} \FunctionTok{getBorrowDays}\OperatorTok{();} \CommentTok{// 借书期限}
\OperatorTok{\}}

\KeywordTok{public} \KeywordTok{class}\NormalTok{ Student }\KeywordTok{extends}\NormalTok{ User }\OperatorTok{\{}
    \KeywordTok{private} \BuiltInTok{String}\NormalTok{ studentNo}\OperatorTok{;}
    \KeywordTok{private} \BuiltInTok{String}\NormalTok{ grade}\OperatorTok{;}
    
    \AttributeTok{@Override}
    \KeywordTok{public} \DataTypeTok{int} \FunctionTok{getMaxBooks}\OperatorTok{()} \OperatorTok{\{} \ControlFlowTok{return} \DecValTok{5}\OperatorTok{;} \OperatorTok{\}}
    
    \AttributeTok{@Override}
    \KeywordTok{public} \DataTypeTok{int} \FunctionTok{getBorrowDays}\OperatorTok{()} \OperatorTok{\{} \ControlFlowTok{return} \DecValTok{30}\OperatorTok{;} \OperatorTok{\}}
\OperatorTok{\}}

\KeywordTok{public} \KeywordTok{class}\NormalTok{ Teacher }\KeywordTok{extends}\NormalTok{ User }\OperatorTok{\{}
    \KeywordTok{private} \BuiltInTok{String}\NormalTok{ teacherNo}\OperatorTok{;}
    \KeywordTok{private} \BuiltInTok{String}\NormalTok{ department}\OperatorTok{;}
    
    \AttributeTok{@Override}
    \KeywordTok{public} \DataTypeTok{int} \FunctionTok{getMaxBooks}\OperatorTok{()} \OperatorTok{\{} \ControlFlowTok{return} \DecValTok{10}\OperatorTok{;} \OperatorTok{\}}
    
    \AttributeTok{@Override}
    \KeywordTok{public} \DataTypeTok{int} \FunctionTok{getBorrowDays}\OperatorTok{()} \OperatorTok{\{} \ControlFlowTok{return} \DecValTok{60}\OperatorTok{;} \OperatorTok{\}}
\OperatorTok{\}}
\end{Highlighting}
\end{Shaded}
\end{block}
\end{frame}

\begin{frame}[fragile]{第27页：方法设计的细节}
\protect\phantomsection\label{ux7b2c27ux9875ux65b9ux6cd5ux8bbeux8ba1ux7684ux7ec6ux8282}
\begin{block}{方法设计检查清单}
\protect\phantomsection\label{ux65b9ux6cd5ux8bbeux8ba1ux68c0ux67e5ux6e05ux5355}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}ll@{}}
\toprule\noalign{}
检查项 & 图书管理系统示例 \\
\midrule\noalign{}
\endhead
\textbf{方法名} & 动词+名词，如\texttt{borrowBook}而非\texttt{borrow} \\
\textbf{参数} & 最小化，优先使用对象而非多个参数 \\
\textbf{返回值} & 明确成功/失败，使用异常或结果对象 \\
\textbf{可见性} & 对外接口public，内部辅助private \\
\textbf{单一职责} & 一个方法只做一件事 \\
\bottomrule\noalign{}
\end{longtable}
}
\end{block}

\begin{block}{反例与正例}
\protect\phantomsection\label{ux53cdux4f8bux4e0eux6b63ux4f8b}
\begin{Shaded}
\begin{Highlighting}[]
\CommentTok{// ❌ 反例：方法职责过多，参数混乱}
\KeywordTok{public} \DataTypeTok{void} \FunctionTok{handleBook}\OperatorTok{(}\BuiltInTok{String}\NormalTok{ userId}\OperatorTok{,} \BuiltInTok{String}\NormalTok{ bookId}\OperatorTok{,} 
                      \DataTypeTok{boolean}\NormalTok{ isBorrow}\OperatorTok{,} \BuiltInTok{Date}\NormalTok{ date}\OperatorTok{)} \OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}}

\CommentTok{// ✅ 正例：职责单一，参数清晰}
\KeywordTok{public}\NormalTok{ BorrowRecord }\FunctionTok{borrowBook}\OperatorTok{(}\BuiltInTok{Book}\NormalTok{ book}\OperatorTok{)} \KeywordTok{throws}\NormalTok{ BorrowException }\OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}}
\KeywordTok{public} \DataTypeTok{void} \FunctionTok{returnBook}\OperatorTok{(}\NormalTok{BorrowRecord }\KeywordTok{record}\OperatorTok{)} \KeywordTok{throws}\NormalTok{ ReturnException }\OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}}
\end{Highlighting}
\end{Shaded}
\end{block}
\end{frame}

\begin{frame}[fragile]{第28页：设计类图（详细版）}
\protect\phantomsection\label{ux7b2c28ux9875ux8bbeux8ba1ux7c7bux56feux8be6ux7ec6ux7248}
\begin{block}{图书管理系统设计类图（简化）}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux8bbeux8ba1ux7c7bux56feux7b80ux5316}
\begin{verbatim}
┌─────────────────────────────────────────────────────────┐
│                      User (abstract)                     │
│  - userId: String                                        │
│  - name: String                                          │
│  - email: String                                         │
│  - borrowRecords: List<BorrowRecord>                     │
│  + canBorrow(): boolean                                  │
│  + borrowBook(Book): BorrowRecord                        │
│  + getMaxBooks(): int {abstract}                         │
└─────────────────────────────────────────────────────────┘
     △
    /|\\
┌───┐ ┌───┐
│Student│ │Teacher│
│-studentNo│ │-teacherNo│
│-grade: String│ │-department: String│
│+getMaxBooks(): 5│ │+getMaxBooks(): 10│
└───┘ └───┘

┌─────────────┐         ┌──────────────────┐
│     Book    │         │  BorrowRecord    │
│ - isbn: String│◄──────│  - recordId: String│
│ - title: String│  1 * │  - borrowDate: Date│
│ - author: String│      │  - dueDate: Date   │
│ - status: Enum │      │  - returnDate: Date│
│ + isAvailable(): boolean│ - status: Enum    │
│ + borrow(): void        │  + isOverdue(): boolean│
└─────────────┘         │  + calculateFine(): double│
                        └──────────────────┘
\end{verbatim}
\end{block}
\end{frame}

\begin{frame}
\end{frame}

\section{第四部分：SOLID设计原则}\label{ux7b2cux56dbux90e8ux5206solidux8bbeux8ba1ux539fux5219}

\begin{frame}{第四部分：SOLID设计原则}
\emph{本部分回答：如何评判设计的好坏？}
\end{frame}

\begin{frame}{第29页：什么是好的OO设计？}
\protect\phantomsection\label{ux7b2c29ux9875ux4ec0ux4e48ux662fux597dux7684ooux8bbeux8ba1}
\begin{block}{设计质量评估标准}
\protect\phantomsection\label{ux8bbeux8ba1ux8d28ux91cfux8bc4ux4f30ux6807ux51c6}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}lll@{}}
\toprule\noalign{}
标准 & 含义 & 反面（坏味道） \\
\midrule\noalign{}
\endhead
\textbf{可维护性} & 易于修改bug & 修改一处，到处报错 \\
\textbf{可扩展性} & 易于添加功能 & 新增功能需要修改大量现有代码 \\
\textbf{可复用性} & 组件可在其他系统使用 & 代码高度耦合，无法单独提取 \\
\textbf{可读性} & 易于理解设计意图 & 命名混乱，结构复杂 \\
\bottomrule\noalign{}
\end{longtable}
}
\end{block}

\begin{block}{SOLID原则的作用}
\protect\phantomsection\label{solidux539fux5219ux7684ux4f5cux7528}
\begin{quote}
\textbf{SOLID = 5个原则的首字母缩写，指导高内聚、低耦合的设计}
\end{quote}

\begin{itemize}
\tightlist
\item
  \textbf{S}ingle Responsibility Principle（单一职责）
\item
  \textbf{O}pen/Closed Principle（开闭原则）
\item
  \textbf{L}iskov Substitution Principle（里氏替换）
\item
  \textbf{I}nterface Segregation Principle（接口隔离）
\item
  \textbf{D}ependency Inversion Principle（依赖倒置）
\end{itemize}
\end{block}
\end{frame}

\begin{frame}[fragile]{第30页：S - 单一职责原则（SRP）}
\protect\phantomsection\label{ux7b2c30ux9875s---ux5355ux4e00ux804cux8d23ux539fux5219srp}
\begin{block}{定义}
\protect\phantomsection\label{ux5b9aux4e49}
\begin{quote}
\textbf{一个类应该只有一个引起它变化的原因}
\end{quote}
\end{block}

\begin{block}{图书管理系统反例}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux53cdux4f8b}
\begin{Shaded}
\begin{Highlighting}[]
\CommentTok{// ❌ 违反SRP：User类同时处理业务逻辑和数据库操作}
\KeywordTok{public} \KeywordTok{class}\NormalTok{ User }\OperatorTok{\{}
    \KeywordTok{private} \BuiltInTok{String}\NormalTok{ userId}\OperatorTok{;}
    \KeywordTok{private} \BuiltInTok{String}\NormalTok{ name}\OperatorTok{;}
    
    \KeywordTok{public} \DataTypeTok{void} \FunctionTok{borrowBook}\OperatorTok{(}\BuiltInTok{Book}\NormalTok{ book}\OperatorTok{)} \OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}}  \CommentTok{// 业务逻辑}
    
    \KeywordTok{public} \DataTypeTok{void} \FunctionTok{saveToDatabase}\OperatorTok{()} \OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}}        \CommentTok{// 持久化逻辑}
    \KeywordTok{public} \DataTypeTok{void} \FunctionTok{sendEmailNotification}\OperatorTok{()} \OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}} \CommentTok{// 通知逻辑}
\OperatorTok{\}}
\end{Highlighting}
\end{Shaded}
\end{block}

\begin{block}{正例：职责分离}
\protect\phantomsection\label{ux6b63ux4f8bux804cux8d23ux5206ux79bb}
\begin{Shaded}
\begin{Highlighting}[]
\CommentTok{// ✅ 业务逻辑}
\KeywordTok{public} \KeywordTok{class}\NormalTok{ User }\OperatorTok{\{}
    \KeywordTok{public}\NormalTok{ BorrowRecord }\FunctionTok{borrowBook}\OperatorTok{(}\BuiltInTok{Book}\NormalTok{ book}\OperatorTok{)} \OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}}
\OperatorTok{\}}

\CommentTok{// ✅ 持久化职责}
\KeywordTok{public} \KeywordTok{class}\NormalTok{ UserRepository }\OperatorTok{\{}
    \KeywordTok{public} \DataTypeTok{void} \FunctionTok{save}\OperatorTok{(}\NormalTok{User user}\OperatorTok{)} \OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}}
    \KeywordTok{public}\NormalTok{ User }\FunctionTok{findById}\OperatorTok{(}\BuiltInTok{String}\NormalTok{ id}\OperatorTok{)} \OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}}
\OperatorTok{\}}

\CommentTok{// ✅ 通知职责}
\KeywordTok{public} \KeywordTok{class}\NormalTok{ NotificationService }\OperatorTok{\{}
    \KeywordTok{public} \DataTypeTok{void} \FunctionTok{sendEmail}\OperatorTok{(}\NormalTok{User user}\OperatorTok{,} \BuiltInTok{String}\NormalTok{ message}\OperatorTok{)} \OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}}
\OperatorTok{\}}
\end{Highlighting}
\end{Shaded}
\end{block}
\end{frame}

\begin{frame}[fragile]{第31页：O - 开闭原则（OCP）}
\protect\phantomsection\label{ux7b2c31ux9875o---ux5f00ux95edux539fux5219ocp}
\begin{block}{定义}
\protect\phantomsection\label{ux5b9aux4e49-1}
\begin{quote}
\textbf{对扩展开放，对修改关闭}
\end{quote}

\begin{itemize}
\tightlist
\item
  \textbf{扩展开放}：新增功能时，可以添加新代码
\item
  \textbf{修改关闭}：不修改已有正常工作的代码
\end{itemize}
\end{block}

\begin{block}{图书管理系统场景：逾期罚款计算}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux573aux666fux903eux671fux7f5aux6b3eux8ba1ux7b97}
\textbf{需求变化}：平时罚款0.5元/天，寒暑假期间0.3元/天

\begin{Shaded}
\begin{Highlighting}[]
\CommentTok{// ❌ 违反OCP：每次变化都要修改现有代码}
\KeywordTok{public} \KeywordTok{class}\NormalTok{ BorrowRecord }\OperatorTok{\{}
    \KeywordTok{public} \DataTypeTok{double} \FunctionTok{calculateFine}\OperatorTok{()} \OperatorTok{\{}
        \ControlFlowTok{if} \OperatorTok{(}\FunctionTok{isHolidayPeriod}\OperatorTok{())} \OperatorTok{\{}  \CommentTok{// 新增判断，修改了原有方法}
            \ControlFlowTok{return}\NormalTok{ overdueDays }\OperatorTok{*} \FloatTok{0.3}\OperatorTok{;}
        \OperatorTok{\}}
        \ControlFlowTok{return}\NormalTok{ overdueDays }\OperatorTok{*} \FloatTok{0.5}\OperatorTok{;}
    \OperatorTok{\}}
\OperatorTok{\}}

\CommentTok{// ✅ 遵循OCP：通过扩展实现变化}
\KeywordTok{public} \KeywordTok{interface}\NormalTok{ FineCalculator }\OperatorTok{\{}
    \DataTypeTok{double} \FunctionTok{calculate}\OperatorTok{(}\DataTypeTok{int}\NormalTok{ overdueDays}\OperatorTok{);}
\OperatorTok{\}}

\KeywordTok{public} \KeywordTok{class}\NormalTok{ DefaultFineCalculator }\KeywordTok{implements}\NormalTok{ FineCalculator }\OperatorTok{\{}
    \KeywordTok{public} \DataTypeTok{double} \FunctionTok{calculate}\OperatorTok{(}\DataTypeTok{int}\NormalTok{ days}\OperatorTok{)} \OperatorTok{\{} \ControlFlowTok{return}\NormalTok{ days }\OperatorTok{*} \FloatTok{0.5}\OperatorTok{;} \OperatorTok{\}}
\OperatorTok{\}}

\KeywordTok{public} \KeywordTok{class}\NormalTok{ HolidayFineCalculator }\KeywordTok{implements}\NormalTok{ FineCalculator }\OperatorTok{\{}
    \KeywordTok{public} \DataTypeTok{double} \FunctionTok{calculate}\OperatorTok{(}\DataTypeTok{int}\NormalTok{ days}\OperatorTok{)} \OperatorTok{\{} \ControlFlowTok{return}\NormalTok{ days }\OperatorTok{*} \FloatTok{0.3}\OperatorTok{;} \OperatorTok{\}}
\OperatorTok{\}}

\CommentTok{// 使用}
\KeywordTok{public} \KeywordTok{class}\NormalTok{ BorrowRecord }\OperatorTok{\{}
    \KeywordTok{private}\NormalTok{ FineCalculator calculator}\OperatorTok{;}  \CommentTok{// 依赖抽象，可替换实现}
\OperatorTok{\}}
\end{Highlighting}
\end{Shaded}
\end{block}
\end{frame}

\begin{frame}[fragile]{第32页：L - 里氏替换原则（LSP）}
\protect\phantomsection\label{ux7b2c32ux9875l---ux91ccux6c0fux66ffux6362ux539fux5219lsp}
\begin{block}{定义}
\protect\phantomsection\label{ux5b9aux4e49-2}
\begin{quote}
\textbf{子类必须能够替换父类，且程序行为不变}
\end{quote}
\end{block}

\begin{block}{图书管理系统示例}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux793aux4f8b-1}
\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{public} \KeywordTok{abstract} \KeywordTok{class}\NormalTok{ User }\OperatorTok{\{}
    \KeywordTok{public} \KeywordTok{abstract} \DataTypeTok{int} \FunctionTok{getMaxBooks}\OperatorTok{();}  \CommentTok{// 子类决定借书限额}
    \KeywordTok{public} \KeywordTok{abstract} \DataTypeTok{boolean} \FunctionTok{canBorrow}\OperatorTok{();} \CommentTok{// 子类决定借书资格}
\OperatorTok{\}}

\KeywordTok{public} \KeywordTok{class}\NormalTok{ Student }\KeywordTok{extends}\NormalTok{ User }\OperatorTok{\{}
    \KeywordTok{public} \DataTypeTok{int} \FunctionTok{getMaxBooks}\OperatorTok{()} \OperatorTok{\{} \ControlFlowTok{return} \DecValTok{5}\OperatorTok{;} \OperatorTok{\}}
    \KeywordTok{public} \DataTypeTok{boolean} \FunctionTok{canBorrow}\OperatorTok{()} \OperatorTok{\{} 
        \ControlFlowTok{return}\NormalTok{ 当前借书数 }\OperatorTok{\textless{}} \DecValTok{5} \OperatorTok{\&\&}\NormalTok{ 无逾期记录}\OperatorTok{;} 
    \OperatorTok{\}}
\OperatorTok{\}}

\KeywordTok{public} \KeywordTok{class}\NormalTok{ Teacher }\KeywordTok{extends}\NormalTok{ User }\OperatorTok{\{}
    \KeywordTok{public} \DataTypeTok{int} \FunctionTok{getMaxBooks}\OperatorTok{()} \OperatorTok{\{} \ControlFlowTok{return} \DecValTok{10}\OperatorTok{;} \OperatorTok{\}}
    \KeywordTok{public} \DataTypeTok{boolean} \FunctionTok{canBorrow}\OperatorTok{()} \OperatorTok{\{} 
        \ControlFlowTok{return}\NormalTok{ 当前借书数 }\OperatorTok{\textless{}} \DecValTok{10}\OperatorTok{;}  \CommentTok{// 教师不受逾期限制}
    \OperatorTok{\}}
\OperatorTok{\}}

\CommentTok{// 使用：任何User子类都可以替换}
\KeywordTok{public} \DataTypeTok{void} \FunctionTok{processBorrow}\OperatorTok{(}\NormalTok{User user}\OperatorTok{,} \BuiltInTok{Book}\NormalTok{ book}\OperatorTok{)} \OperatorTok{\{}
    \ControlFlowTok{if} \OperatorTok{(}\NormalTok{user}\OperatorTok{.}\FunctionTok{canBorrow}\OperatorTok{())} \OperatorTok{\{}  \CommentTok{// 无需知道具体类型}
\NormalTok{        user}\OperatorTok{.}\FunctionTok{borrowBook}\OperatorTok{(}\NormalTok{book}\OperatorTok{);}
    \OperatorTok{\}}
\OperatorTok{\}}
\end{Highlighting}
\end{Shaded}
\end{block}

\begin{block}{违反LSP的危险}
\protect\phantomsection\label{ux8fddux53cdlspux7684ux5371ux9669}
\begin{itemize}
\tightlist
\item
  如果Student子类抛出异常或返回意外结果，替换后程序崩溃
\end{itemize}
\end{block}
\end{frame}

\begin{frame}[fragile]{第33页：I - 接口隔离原则（ISP）}
\protect\phantomsection\label{ux7b2c33ux9875i---ux63a5ux53e3ux9694ux79bbux539fux5219isp}
\begin{block}{定义}
\protect\phantomsection\label{ux5b9aux4e49-3}
\begin{quote}
\textbf{客户端不应该依赖它不需要的接口}
\end{quote}
\end{block}

\begin{block}{图书管理系统反例}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux53cdux4f8b-1}
\begin{Shaded}
\begin{Highlighting}[]
\CommentTok{// ❌ 胖接口：强迫实现不需要的方法}
\KeywordTok{public} \KeywordTok{interface}\NormalTok{ LibraryService }\OperatorTok{\{}
    \DataTypeTok{void} \FunctionTok{addBook}\OperatorTok{(}\BuiltInTok{Book}\NormalTok{ book}\OperatorTok{);}           \CommentTok{// 管理员需要}
    \DataTypeTok{void} \FunctionTok{deleteBook}\OperatorTok{(}\BuiltInTok{String}\NormalTok{ isbn}\OperatorTok{);}      \CommentTok{// 管理员需要}
\NormalTok{    BorrowRecord }\FunctionTok{borrowBook}\OperatorTok{(}\BuiltInTok{String}\NormalTok{ userId}\OperatorTok{,} \BuiltInTok{String}\NormalTok{ isbn}\OperatorTok{);}  \CommentTok{// 用户需要}
    \DataTypeTok{void} \FunctionTok{returnBook}\OperatorTok{(}\BuiltInTok{String}\NormalTok{ recordId}\OperatorTok{);}  \CommentTok{// 用户需要}
    \DataTypeTok{double} \FunctionTok{calculateFine}\OperatorTok{(}\BuiltInTok{String}\NormalTok{ recordId}\OperatorTok{);}  \CommentTok{// 系统需要}
\OperatorTok{\}}

\KeywordTok{public} \KeywordTok{class}\NormalTok{ StudentService }\KeywordTok{implements}\NormalTok{ LibraryService }\OperatorTok{\{}
    \CommentTok{// 学生被迫实现addBook、deleteBook，抛出异常}
    \KeywordTok{public} \DataTypeTok{void} \FunctionTok{addBook}\OperatorTok{(}\BuiltInTok{Book}\NormalTok{ book}\OperatorTok{)} \OperatorTok{\{} 
        \ControlFlowTok{throw} \KeywordTok{new} \BuiltInTok{UnsupportedOperationException}\OperatorTok{();} 
    \OperatorTok{\}}
\OperatorTok{\}}
\end{Highlighting}
\end{Shaded}
\end{block}

\begin{block}{正例：接口拆分}
\protect\phantomsection\label{ux6b63ux4f8bux63a5ux53e3ux62c6ux5206}
\begin{Shaded}
\begin{Highlighting}[]
\CommentTok{// ✅ 小接口，职责单一}
\KeywordTok{public} \KeywordTok{interface}\NormalTok{ BookManagementService }\OperatorTok{\{}
    \DataTypeTok{void} \FunctionTok{addBook}\OperatorTok{(}\BuiltInTok{Book}\NormalTok{ book}\OperatorTok{);}
    \DataTypeTok{void} \FunctionTok{deleteBook}\OperatorTok{(}\BuiltInTok{String}\NormalTok{ isbn}\OperatorTok{);}
\OperatorTok{\}}

\KeywordTok{public} \KeywordTok{interface}\NormalTok{ BorrowService }\OperatorTok{\{}
\NormalTok{    BorrowRecord }\FunctionTok{borrowBook}\OperatorTok{(}\BuiltInTok{String}\NormalTok{ userId}\OperatorTok{,} \BuiltInTok{String}\NormalTok{ isbn}\OperatorTok{);}
    \DataTypeTok{void} \FunctionTok{returnBook}\OperatorTok{(}\BuiltInTok{String}\NormalTok{ recordId}\OperatorTok{);}
\OperatorTok{\}}

\KeywordTok{public} \KeywordTok{interface}\NormalTok{ FineCalculationService }\OperatorTok{\{}
    \DataTypeTok{double} \FunctionTok{calculateFine}\OperatorTok{(}\BuiltInTok{String}\NormalTok{ recordId}\OperatorTok{);}
\OperatorTok{\}}

\CommentTok{// 学生只需实现BorrowService}
\KeywordTok{public} \KeywordTok{class}\NormalTok{ StudentBorrowService }\KeywordTok{implements}\NormalTok{ BorrowService }\OperatorTok{\{} \KeywordTok{...} \OperatorTok{\}}
\end{Highlighting}
\end{Shaded}
\end{block}
\end{frame}

\begin{frame}[fragile]{第34页：D - 依赖倒置原则（DIP）}
\protect\phantomsection\label{ux7b2c34ux9875d---ux4f9dux8d56ux5012ux7f6eux539fux5219dip}
\begin{block}{定义}
\protect\phantomsection\label{ux5b9aux4e49-4}
\begin{quote}
\textbf{高层模块不应该依赖低层模块，两者都应该依赖抽象}
\end{quote}
\end{block}

\begin{block}{图书管理系统示例}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux793aux4f8b-2}
\begin{Shaded}
\begin{Highlighting}[]
\CommentTok{// ❌ 违反DIP：BorrowService直接依赖具体实现}
\KeywordTok{public} \KeywordTok{class}\NormalTok{ BorrowService }\OperatorTok{\{}
    \KeywordTok{private}\NormalTok{ MySQLUserRepository userRepo}\OperatorTok{;}  \CommentTok{// 依赖具体数据库}
    \KeywordTok{private}\NormalTok{ MySQLBookRepository bookRepo}\OperatorTok{;}  \CommentTok{// 依赖具体数据库}
    
    \KeywordTok{public} \FunctionTok{BorrowService}\OperatorTok{()} \OperatorTok{\{}
        \KeywordTok{this}\OperatorTok{.}\FunctionTok{userRepo} \OperatorTok{=} \KeywordTok{new} \FunctionTok{MySQLUserRepository}\OperatorTok{();}  \CommentTok{// 硬编码}
        \KeywordTok{this}\OperatorTok{.}\FunctionTok{bookRepo} \OperatorTok{=} \KeywordTok{new} \FunctionTok{MySQLBookRepository}\OperatorTok{();}
    \OperatorTok{\}}
\OperatorTok{\}}

\CommentTok{// ✅ 遵循DIP：依赖抽象接口}
\KeywordTok{public} \KeywordTok{class}\NormalTok{ BorrowService }\OperatorTok{\{}
    \KeywordTok{private}\NormalTok{ UserRepository userRepo}\OperatorTok{;}  \CommentTok{// 依赖接口}
    \KeywordTok{private}\NormalTok{ BookRepository bookRepo}\OperatorTok{;}  \CommentTok{// 依赖接口}
    
    \KeywordTok{public} \FunctionTok{BorrowService}\OperatorTok{(}\NormalTok{UserRepository userRepo}\OperatorTok{,} 
\NormalTok{                        BookRepository bookRepo}\OperatorTok{)} \OperatorTok{\{}
        \KeywordTok{this}\OperatorTok{.}\FunctionTok{userRepo} \OperatorTok{=}\NormalTok{ userRepo}\OperatorTok{;}  \CommentTok{// 通过构造器注入}
        \KeywordTok{this}\OperatorTok{.}\FunctionTok{book\_repo} \OperatorTok{=}\NormalTok{ book\_repo}\OperatorTok{;}
    \OperatorTok{\}}
\OperatorTok{\}}

\CommentTok{// 可以注入MySQL实现、MongoDB实现、内存实现（测试用）}
\end{Highlighting}
\end{Shaded}
\end{block}
\end{frame}

