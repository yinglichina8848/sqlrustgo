\begin{frame}{第44页：常见问题解答}
\protect\phantomsection\label{ux7b2c44ux9875ux5e38ux89c1ux95eeux9898ux89e3ux7b54}
\begin{block}{Q1：OOA和OOD的界限在哪里？}
\protect\phantomsection\label{q1ooaux548coodux7684ux754cux9650ux5728ux54eaux91cc}
\textbf{A}：OOA关注''做什么''（业务概念），OOD关注''怎么做''（技术实现）。界限不是绝对的，是渐进细化的过程。
\end{block}

\begin{block}{Q2：如何判断一个名词是否应该成为对象？}
\protect\phantomsection\label{q2ux5982ux4f55ux5224ux65adux4e00ux4e2aux540dux8bcdux662fux5426ux5e94ux8be5ux6210ux4e3aux5bf9ux8c61}
\textbf{A}：看它是否有明确的责任（行为）。如果只是数据容器，可能是属性；如果有业务规则需要封装，应该是对象。
\end{block}

\begin{block}{Q3：SOLID原则必须全部遵循吗？}
\protect\phantomsection\label{q3solidux539fux5219ux5fc5ux987bux5168ux90e8ux9075ux5faaux5417}
\textbf{A}：不是教条，是指导原则。实际项目中需要权衡，但SRP和OCP建议优先遵循。
\end{block}

\begin{block}{Q4：设计模式什么时候用？}
\protect\phantomsection\label{q4ux8bbeux8ba1ux6a21ux5f0fux4ec0ux4e48ux65f6ux5019ux7528}
\textbf{A}：不要过早使用。当代码出现坏味道（重复、难以扩展）时，再考虑重构为设计模式。
\end{block}
\end{frame}

