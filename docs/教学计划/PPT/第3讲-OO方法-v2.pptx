\end{frame}

\begin{frame}
\end{frame}

\section{第二部分：面向对象分析（OOA）}\label{ux7b2cux4e8cux90e8ux5206ux9762ux5411ux5bf9ux8c61ux5206ux6790ooa}

\begin{frame}{第二部分：面向对象分析（OOA）}
\emph{本部分回答：如何从需求中发现对象？}
\end{frame}

\begin{frame}{第11页：OOA的核心任务}
\protect\phantomsection\label{ux7b2c11ux9875ooaux7684ux6838ux5fc3ux4efbux52a1}
\begin{block}{什么是OOA？}
\protect\phantomsection\label{ux4ec0ux4e48ux662fooa}
\begin{quote}
\textbf{面向对象分析（OOA）= 理解问题域，建立概念模型的过程}
\end{quote}
\end{block}

\begin{block}{核心任务}
\protect\phantomsection\label{ux6838ux5fc3ux4efbux52a1}
\begin{enumerate}
\tightlist
\item
  \textbf{理解需求}：与领域专家沟通，收集功能需求
\item
  \textbf{识别对象}：从需求描述中发现业务实体
\item
  \textbf{确定属性}：对象的特征信息
\item
  \textbf{识别关系}：对象之间的关联、继承、依赖
\item
  \textbf{产出模型}：用例图、概念类图、活动图
\end{enumerate}
\end{block}

\begin{block}{图书管理系统OOA产出示例}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfooaux4ea7ux51faux793aux4f8b}
\begin{itemize}
\tightlist
\item
  用例图：学生借书、还书、查询；管理员管理图书\ldots{}
\item
  概念类图：学生、教师、图书、借阅记录、逾期罚款\ldots{}
\end{itemize}
\end{block}
\end{frame}

\begin{frame}{第12页：需求获取：用例分析}
\protect\phantomsection\label{ux7b2c12ux9875ux9700ux6c42ux83b7ux53d6ux7528ux4f8bux5206ux6790}
\begin{block}{图书管理系统需求（简化版）}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux9700ux6c42ux7b80ux5316ux7248}
\begin{quote}
\textbf{用户故事}：

\begin{enumerate}
\tightlist
\item
  学生和教师可以借阅图书，每本书最多借30天
\item
  逾期每天罚款0.5元，最高不超过书价
\item
  管理员可以添加、删除、修改图书信息
\item
  用户可以查询图书信息和借阅历史
\item
  系统需要记录所有借阅历史
\end{enumerate}
\end{quote}
\end{block}

\begin{block}{用例识别}
\protect\phantomsection\label{ux7528ux4f8bux8bc6ux522b}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}ll@{}}
\toprule\noalign{}
参与者 & 用例（功能） \\
\midrule\noalign{}
\endhead
学生 & 借书、还书、查询图书、查看借阅历史 \\
教师 & 借书、还书、查询图书、查看借阅历史 \\
管理员 & 图书管理（增删改）、查看统计报表 \\
系统 & 计算逾期罚款、发送催还通知 \\
\bottomrule\noalign{}
\end{longtable}
}
\end{block}
\end{frame}

\begin{frame}{第13页：名词分析法：发现对象}
\protect\phantomsection\label{ux7b2c13ux9875ux540dux8bcdux5206ux6790ux6cd5ux53d1ux73b0ux5bf9ux8c61}
\begin{block}{方法步骤}
\protect\phantomsection\label{ux65b9ux6cd5ux6b65ux9aa4}
\begin{enumerate}
\tightlist
\item
  \textbf{划线}：从需求描述中划出所有名词
\item
  \textbf{筛选}：排除系统、界面、外部系统，保留业务实体
\item
  \textbf{分类}：区分对象、属性、值对象
\item
  \textbf{验证}：检查对象是否有明确的责任
\end{enumerate}
\end{block}

\begin{block}{图书管理系统名词分析}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux540dux8bcdux5206ux6790}
\begin{quote}
``\textbf{学生}和\textbf{教师}可以\textbf{借阅图书}。每本\textbf{图书}有\textbf{ISBN}、\textbf{书名}、\textbf{作者}、\textbf{出版社}。\textbf{借阅}时需登记\textbf{借阅人}、\textbf{借阅日期}、\textbf{应还日期}。\textbf{图书管理员}负责管理\textbf{图书}和\textbf{借阅记录}。\textbf{系统}需要记录\textbf{借阅历史}，并支持\textbf{逾期罚款}计算。''
\end{quote}
\end{block}
\end{frame}

\begin{frame}{第14页：候选对象筛选}
\protect\phantomsection\label{ux7b2c14ux9875ux5019ux9009ux5bf9ux8c61ux7b5bux9009}
\begin{block}{第一轮筛选：排除非业务实体}
\protect\phantomsection\label{ux7b2cux4e00ux8f6eux7b5bux9009ux6392ux9664ux975eux4e1aux52a1ux5b9eux4f53}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}lll@{}}
\toprule\noalign{}
候选名词 & 判断 & 理由 \\
\midrule\noalign{}
\endhead
学生 & ✅ 保留 & 业务实体，有明确责任（借书、还书） \\
教师 & ✅ 保留 & 业务实体，与学生类似但权限不同 \\
图书 & ✅ 保留 & 核心业务实体 \\
ISBN & ❌ 排除 & 图书的属性，不是独立对象 \\
书名 & ❌ 排除 & 图书的属性 \\
作者 & ❌ 排除 & 图书的属性（或单独对象，视复杂度） \\
出版社 & ❌ 排除 & 图书的属性（简化处理） \\
借阅 & ✅ 保留 & 业务实体，需要记录状态 \\
借阅人 & ❌ 排除 & 学生/教师的引用 \\
借阅日期 & ❌ 排除 & 借阅记录的属性 \\
应还日期 & ❌ 排除 & 借阅记录的属性 \\
图书管理员 & ✅ 保留 & 业务实体（或与用户合并） \\
借阅记录 & ✅ 保留 & 核心业务实体 \\
系统 & ❌ 排除 & 边界外 \\
借阅历史 & ❌ 排除 & 借阅记录的集合 \\
逾期罚款 & ⚠️ 值对象 & 无独立身份，依附于借阅记录 \\
\bottomrule\noalign{}
\end{longtable}
}
\end{block}
\end{frame}

\begin{frame}[fragile]{第15页：对象分类与泛化}
\protect\phantomsection\label{ux7b2c15ux9875ux5bf9ux8c61ux5206ux7c7bux4e0eux6cdbux5316}
\begin{block}{识别泛化关系（继承）}
\protect\phantomsection\label{ux8bc6ux522bux6cdbux5316ux5173ux7cfbux7ee7ux627f}
\begin{verbatim}
        用户（User）
       /          \
    学生（Student）  教师（Teacher）
    - 学号          - 教师工号
    - 年级          - 院系
    - 最大借书数=5   - 最大借书数=10
\end{verbatim}
\end{block}

\begin{block}{图书管理系统核心对象（第一版）}
\protect\phantomsection\label{ux56feux4e66ux7ba1ux7406ux7cfbux7edfux6838ux5fc3ux5bf9ux8c61ux7b2cux4e00ux7248}
{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}lll@{}}
\toprule\noalign{}
对象 & 类型 & 核心责任 \\
\midrule\noalign{}
\endhead
User（用户） & 抽象类 & 登录、查看个人信息 \\
Student（学生） & 具体类 & 借书、还书、查询（限制5本） \\
Teacher（教师） & 具体类 & 借书、还书、查询（限制10本） \\
Book（图书） & 具体类 & 记录状态（可借/已借出）、验证ISBN \\
BorrowRecord（借阅记录） & 具体类 & 记录借阅信息、计算逾期罚款 \\
Librarian（图书管理员） & 具体类 & 管理图书信息 \\
\bottomrule\noalign{}
\end{longtable}
}
\end{block}
\end{frame}

