{
  "version": "0.2",
  "schema": "hermes-core-v1",
  "rules": [
    {
      "id": "PROOF_VERIFIED",
      "description": "PRs are only acceptable when the system has a VERIFIED baseline. Prevents merging onto an unproven system state.",
      "version": "1.0",
      "condition": {
        "type": "ALWAYS"
      },
      "proof_check": {
        "report_path": "docs/versions/v2.8.0/verification_report.json",
        "required_field": "baseline_verified",
        "required_value": "true",
        "fallback": "BLOCK"
      },
      "action": "BLOCK",
      "severity": "CRITICAL",
      "blocking": true,
      "message": "System baseline is not VERIFIED. Run verification_engine before merging."
    },
    {
      "id": "AUDIT_TRUSTED",
      "description": "PRs require a passing self-audit, proving CI path and Audit path agree (detects AV4 tampering).",
      "version": "1.0",
      "condition": {
        "type": "ALWAYS"
      },
      "audit_check": {
        "report_path": "docs/versions/v2.8.0/audit_report.json",
        "required_field": "status",
        "required_value": "TRUSTED",
        "fallback": "BLOCK"
      },
      "action": "BLOCK",
      "severity": "CRITICAL",
      "blocking": true,
      "message": "Self-audit is not TRUSTED. Run self_audit.py before merging."
    },
    {
      "id": "REQUIRE_ISSUE",
      "description": "PR must be linked to an ISSUE, otherwise FAIL",
      "version": "1.0",
      "condition": {
        "type": "AND",
        "checks": [
          {
            "field": "pr_body",
            "operator": "REGEX",
            "value": "closes?\\s+#\\d+|fixes?\\s+#\\d+|refs?\\s+#\\d+"
          }
        ]
      },
      "action": "FAIL",
      "severity": "CRITICAL",
      "blocking": true,
      "message": "PR must reference an ISSUE (e.g. 'Closes #1234')"
    },
    {
      "id": "SQL_SEMANTIC_TEST",
      "description": "If modifying executor/SQL logic, must include NULL and JOIN+WHERE tests",
      "version": "1.0",
      "condition": {
        "type": "OR",
        "checks": [
          {
            "field": "changed_files",
            "operator": "CONTAINS",
            "value": "executor"
          },
          {
            "field": "changed_files",
            "operator": "CONTAINS",
            "value": "parser"
          },
          {
            "field": "changed_files",
            "operator": "CONTAINS",
            "value": "planner"
          },
          {
            "field": "changed_files",
            "operator": "CONTAINS",
            "value": "storage"
          }
        ]
      },
      "required_tests": {
        "NULL_test": {
          "description": "NULL three-value logic tests must exist",
          "severity": "CRITICAL"
        },
        "JOIN_WHERE_test": {
          "description": "JOIN + WHERE tests must exist",
          "severity": "CRITICAL"
        }
      },
      "action": "FAIL",
      "severity": "CRITICAL",
      "blocking": true,
      "message": "SQL/executor changes require NULL logic tests AND JOIN+WHERE tests. Run full test suite for ground truth."
    },
    {
      "id": "ROADMAP_PRIORITY",
      "description": "Block P1/P2 PRs when P0 issues are incomplete",
      "version": "1.0",
      "condition": {
        "type": "OR",
        "checks": [
          {
            "field": "pr_labels",
            "operator": "CONTAINS",
            "value": "P1"
          },
          {
            "field": "pr_labels",
            "operator": "CONTAINS",
            "value": "P2"
          }
        ]
      },
      "p0_gate": {
        "type": "FILE_EXISTS",
        "path": "docs/roadmap.json",
        "check_unfinished_p0": true,
        "severity": "CRITICAL"
      },
      "action": "BLOCK",
      "severity": "HIGH",
      "blocking": true,
      "message": "P1/P2 PR blocked: unfinished P0 issues exist in roadmap"
    },
    {
      "id": "TEST_COMPLETENESS",
      "description": "Every code PR must include happy path, edge case, and regression tests",
      "version": "1.0",
      "condition": {
        "type": "AND",
        "checks": [
          {
            "field": "changed_files",
            "operator": "NOT_CONTAINS",
            "value": "*.md"
          },
          {
            "field": "changed_files",
            "operator": "NOT_CONTAINS",
            "value": "docs/"
          },
          {
            "field": "changed_files",
            "operator": "NOT_CONTAINS",
            "value": "wiki/"
          }
        ]
      },
      "required_test_categories": {
        "happy_path": {
          "description": "Happy-path / smoke test",
          "severity": "HIGH"
        },
        "edge_case": {
          "description": "Edge-case / boundary test",
          "severity": "HIGH"
        },
        "regression": {
          "description": "Regression test for bug fixes",
          "severity": "HIGH"
        }
      },
      "action": "FAIL",
      "severity": "HIGH",
      "blocking": true,
      "message": "PR must include happy-path, edge-case, and regression tests. Semantic correctness is verified by CI, not by this gate."
    }
  ],
  "exit_codes": {
    "PASS": 0,
    "FAIL": 1,
    "BLOCK": 2,
    "ERROR": 3
  },
  "architecture": {
    "description": "Gate runs BEFORE CI. Gate checks structure/hygiene. CI + proof + audit provide ground truth.",
    "layers": [
      "hermes_gate.sh (gate check, pre-merge)",
      "cargo test (ground truth, CI)",
      "verification_engine.py (proof generation)",
      "self_audit.py (independent audit)"
    ]
  }
}
