{
  "version": "v2.9.0",
  "contract_type": "hermes_gate_v0.3-improved",
  "baseline": {
    "branch": "develop/v2.9.0",
    "test_count": 3597,
    "features": [
      "E-04 GRANT/REVOKE",
      "C-01 SQL Corpus 85.4%",
      "D-01 Semi-sync replication",
      "D-02 MTS parallel replication",
      "E-02 Slow query log"
    ],
    "new_modules": [
      "crates/distributed/semisync.rs",
      "crates/distributed/mts.rs",
      "crates/distributed/worker_pool.rs"
    ]
  },
  "rules": {
    "R0": {
      "name": "Commit binding",
      "description": "All reports must carry commit field matching HEAD",
      "severity": "CRITICAL",
      "gate": "PRE_MERGE"
    },
    "R1": {
      "name": "Test immutability",
      "description": "Tests must not be modified to make them pass",
      "severity": "CRITICAL",
      "gate": "PRE_MERGE"
    },
    "R2": {
      "name": "No #[ignore] injection",
      "description": "No new #[ignore] attributes allowed",
      "severity": "CRITICAL",
      "gate": "PRE_COMMIT"
    },
    "R3": {
      "name": "Proof authenticity",
      "description": "Verification/audit reports must be generated by CI",
      "severity": "CRITICAL",
      "gate": "CI"
    },
    "R4": {
      "name": "Full execution",
      "description": "All tests must run via cargo test --all-features",
      "severity": "CRITICAL",
      "gate": "CI"
    },
    "R5": {
      "name": "Baseline verification",
      "description": "verification_report.json must show baseline_verified=true, test count >= 3597",
      "severity": "CRITICAL",
      "gate": "PRE_MERGE"
    },
    "R6": {
      "name": "Test count monotonicity",
      "description": "Test count must not decrease from 226 (v2.8.0) / 3597 (v2.9.0)",
      "severity": "HIGH",
      "gate": "POST_MERGE"
    },
    "R7": {
      "name": "CI workflow integrity",
      "description": "CI workflow must not be modified without explicit approval",
      "severity": "HIGH",
      "gate": "REVIEW"
    },
    "R8": {
      "name": "Distributed module gate",
      "description": "PRs touching crates/distributed/ must also run: cargo test -p sqlrustgo-distributed",
      "severity": "HIGH",
      "gate": "CI",
      "new_in_v2.9": true
    },
    "R9": {
      "name": "Cross-platform identity",
      "description": "Each platform must use its own Gitea SSH key, never shared credentials",
      "severity": "MEDIUM",
      "gate": "PRE_MERGE",
      "new_in_v2.9": true
    }
  },
  "invariants": [
    "INV1: \u2200 PR: passes(gate) \u2192 mergeable",
    "INV2: \u2200 commit: references(issue) \u2228 is(doc)",
    "INV3: \u2200 feature: has(tests) \u2227 has(docs) \u2227 has(proof)",
    "INV4: merged(PR) \u2192 has_merged=true",
    "INV5: test_count(v2.9.0) >= test_count(v2.8.0)"
  ],
  "attack_vectors": {
    "AV1": "Direct push to develop/v2.9.0 bypassing PR",
    "AV2": "Merge without CI approval (branch protect disabled)",
    "AV3": "Stale verification report without commit binding",
    "AV4": "PR with too-large diff (>500 lines review threshold)",
    "AV5": "Same branch modified on two platforms simultaneously"
  },
  "enforcement": {
    "gate_exit_codes": {
      "0": "PASS",
      "1": "FAIL",
      "2": "BLOCK",
      "3": "ENV_ERROR"
    },
    "gates": {
      "PRE_COMMIT": "Client-side hook",
      "PRE_MERGE": "Server-side gate",
      "CI": "Gitea Actions",
      "POST_MERGE": "Cron check",
      "REVIEW": "Manual review required"
    }
  },
  "test_phases": {
    "develop": {
      "gate": "CI",
      "tests": [
        "cargo build --workspace",
        "cargo test --lib --all-features",
        "cargo clippy -- -D warnings",
        "cargo fmt --check"
      ]
    },
    "alpha": {
      "gate": "PRE_MERGE",
      "tests": [
        "cargo test --all-features",
        "cargo test --test *",
        "cargo test -p sqlrustgo-sql-corpus",
        "coverage >=50%"
      ]
    },
    "beta": {
      "gate": "PRE_MERGE",
      "tests": [
        "cargo test --all-features",
        "cargo bench --bench tpch_bench -- --quick",
        "bash scripts/sysbench/point_select.sh",
        "cargo test -p sqlrustgo-security",
        "coverage >=65%"
      ]
    },
    "rc": {
      "gate": "BLOCK",
      "tests": [
        "cargo test --all-features",
        "TPC-H QPS baseline",
        "Sysbench OLTP >=5K QPS",
        "Proof verification (PROOF-011~014)",
        "coverage >=80%"
      ]
    },
    "ga": {
      "gate": "BLOCK",
      "tests": [
        "All previous",
        "Chaos engineering",
        "Security audit",
        "coverage >=85%",
        "Proof registry complete"
      ]
    }
  },
  "test_baseline_v2.8": {
    "unit_tests": 226,
    "sql_corpus_pass_rate": "40.8%",
    "ignored_tests": 33
  },
  "test_baseline_v2.9": {
    "unit_tests": 3630,
    "sql_corpus_pass_rate": "85.4%",
    "ignored_tests": 0
  }
}